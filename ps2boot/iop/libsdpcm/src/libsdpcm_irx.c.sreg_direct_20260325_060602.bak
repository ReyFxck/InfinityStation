#include <tamtypes.h>
#include <irx.h>
#include <loadcore.h>
#include <intrman.h>
#include <thbase.h>
#include <sysclib.h>
#include <stdio.h>
#include <sifman.h>
#include <sifrpc.h>

IRX_ID("libsdpcm", 1, 0);

#define LIBSDPCM_RPC_ID 0x014C504D

typedef struct {
    u32 cmd;
    s32 result;
    u32 magic;
    u32 counter;
    u32 pad[12];
} libsdpcm_rpc_pkt_t;

static SifRpcDataQueue_t qd;
static SifRpcServerData_t sd0;
static u8 rpcBuffer[64] __attribute__((aligned(64)));

static void *rpcServer(int fno, void *data, int size)
{
    libsdpcm_rpc_pkt_t *pkt = (libsdpcm_rpc_pkt_t *)data;
    (void)size;

    pkt->magic = LIBSDPCM_RPC_ID;
    pkt->counter++;

    switch (fno) {
        case 1:
        case 2:
        case 3:
        case 4:
            pkt->result = 0;
            break;
        default:
            pkt->result = -1;
            break;
    }

    return data;
}

static void rpcThread(void *arg)
{
    (void)arg;
    SifInitRpc(0);
    SifSetRpcQueue(&qd, GetThreadId());
    SifRegisterRpc(&sd0, LIBSDPCM_RPC_ID, rpcServer, rpcBuffer, 0, 0, &qd);
    SifRpcLoop(&qd);
}

static int start_rpc_thread(void)
{
    iop_thread_t t;
    int thid;
    int r;

    memset(&t, 0, sizeof(t));
    t.attr      = 0x2000000;
    t.thread    = rpcThread;
    t.priority  = 32;
    t.stacksize = 0x1000;
    t.option    = 0;

    thid = CreateThread(&t);
    if (thid <= 0)
        return -1;

    r = StartThread(thid, 0);
    if (r)
        return -1;

    return 0;
}

int _start(int argc, char **argv)
{
    (void)argc;
    (void)argv;

    memset(&qd, 0, sizeof(qd));
    memset(&sd0, 0, sizeof(sd0));
    memset(rpcBuffer, 0, sizeof(rpcBuffer));

    return start_rpc_thread() < 0;
}
