#include <tamtypes.h>
#include <irx.h>
#include <loadcore.h>
#include <intrman.h>
#include <thbase.h>
#include <sysclib.h>
#include <stdio.h>
#include <sifman.h>
#include <sifrpc.h>

IRX_ID("libsdpcm", 1, 0);

#define LIBSDPCM_RPC_ID 0x014C504D

typedef struct {
    u32 cmd;
    s32 result;
    u32 magic;
    u32 counter;
    u32 pad[12];
} libsdpcm_rpc_pkt_t;

static SifRpcDataQueue_t qd;
static SifRpcServerData_t sd0;
static u8 rpcBuffer[64] __attribute__((aligned(64)));

static void *rpcServer(int func, void *data, int size)
{
    libsdpcm_rpc_pkt_t *pkt = (libsdpcm_rpc_pkt_t *)data;
    (void)size;

    pkt->magic = LIBSDPCM_RPC_ID;
    pkt->counter++;

    switch (func) {
        case 1: /* PING */
        case 2: /* INIT */
        case 3: /* QUIT */
        case 4: /* PUSH */
            pkt->result = 0;
            break;
        default:
            pkt->result = -1;
            break;
    }

    return data;
}

static void rpcThread(void *param)
{
    (void)param;
    SifInitRpc(0);
    SifSetRpcQueue(&qd, GetThreadId());
    SifRegisterRpc(&sd0, LIBSDPCM_RPC_ID, rpcServer, (void *)rpcBuffer, 0, 0, &qd);
    SifRpcLoop(&qd);
}

int _start(int argc, char *argv[])
{
    iop_thread_t thread;
    int tid;

    (void)argc;
    (void)argv;

    CpuEnableIntr();

    memset(&qd, 0, sizeof(qd));
    memset(&sd0, 0, sizeof(sd0));
    memset(rpcBuffer, 0, sizeof(rpcBuffer));
    memset(&thread, 0, sizeof(thread));

    thread.attr = TH_C;
    thread.thread = rpcThread;
    thread.priority = 40;
    thread.stacksize = 0x1000;
    thread.option = 0;

    tid = CreateThread(&thread);
    if (tid < 0)
        return MODULE_NO_RESIDENT_END;

    if (StartThread(tid, 0) < 0)
        return MODULE_NO_RESIDENT_END;

    return MODULE_RESIDENT_END;
}
