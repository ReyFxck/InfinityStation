#include <tamtypes.h>
#include <thbase.h>
#include <loadcore.h>
#include <stdio.h>
#include <string.h>
#include <sifrpc.h>
#include <irx.h>
#include <intrman.h>
#include <libsd.h>

IRX_ID("libsdpcm", 1, 0);

#define LIBSDPCM_RPC_ID 0x014C504D

#define LIBSDPCM_RING_SIZE        (64 * 1024)
#define LIBSDPCM_PLAY_CHUNK       1024
#define LIBSDPCM_PLAY_DELAY_FAST  7000
#define LIBSDPCM_PLAY_DELAY_NORM  8000
#define LIBSDPCM_PREFILL_START    (8 * 1024)

#ifndef SD_INIT_COLD
#define SD_INIT_COLD 0
#endif

#ifndef SD_CORE_0
#define SD_CORE_0 0x0000
#endif

#ifndef SD_CORE_1
#define SD_CORE_1 0x0400
#endif

#ifndef SD_TRANS_LOOP
#define SD_TRANS_LOOP 1
#endif

#ifndef SD_TRANS_STOP
#define SD_TRANS_STOP 2
#endif

#ifndef LIBSDPCM_DMA_CH
#define LIBSDPCM_DMA_CH 1
#endif

enum {
    LIBSDPCM_CMD_PING = 1,
    LIBSDPCM_CMD_INIT = 2,
    LIBSDPCM_CMD_QUIT = 3,
    LIBSDPCM_CMD_PUSH = 4
};

typedef struct libsdpcm_rpc_pkt {
    u32 cmd;
    u32 arg0;
    u32 arg1;
    u32 arg2;
    u32 arg3;
    s32 result;
    u32 magic;
    u32 counter;
    u8  payload[2048];
} libsdpcm_rpc_pkt_t;

static SifRpcDataQueue_t g_qd;
static SifRpcServerData_t g_sd0;
static libsdpcm_rpc_pkt_t g_rpc_buf __attribute__((aligned(64)));

static u8  g_ring[LIBSDPCM_RING_SIZE] __attribute__((aligned(64)));
static u32 g_ring_rpos = 0;
static u32 g_ring_wpos = 0;
static u32 g_ring_used = 0;

static u32 g_rpc_counter = 0;
static u32 g_push_calls = 0;
static u32 g_total_in = 0;
static u32 g_drop_bytes = 0;

static u32 g_pop_calls = 0;
static u32 g_total_out = 0;
static u32 g_underflow_bytes = 0;

static int g_audio_initialized = 0;
static int g_player_tid = -1;
static int g_seen_first_push = 0;
static volatile int g_rpc_ready = 0;

static u8 g_play_buf[LIBSDPCM_PLAY_CHUNK] __attribute__((aligned(64)));

static u32 g_backend_calls = 0;
static u32 g_backend_bytes = 0;
static s32 g_backend_peak = 0;

static int g_backend_hw_inited = 0;
static int g_backend_dma_started = 0;
static int g_backend_last_block = -1;
static u8 g_hwbuf[2][LIBSDPCM_PLAY_CHUNK] __attribute__((aligned(64)));

static void ring_lock(int *state)
{
    CpuSuspendIntr(state);
}

static void ring_unlock(int state)
{
    CpuResumeIntr(state);
}

static u32 ring_free_nolock(void)
{
    return LIBSDPCM_RING_SIZE - g_ring_used;
}

static void ring_reset(void)
{
    int state;

    ring_lock(&state);
    g_ring_rpos = 0;
    g_ring_wpos = 0;
    g_ring_used = 0;

    g_rpc_counter = 0;
    g_push_calls = 0;
    g_total_in = 0;
    g_drop_bytes = 0;

    g_pop_calls = 0;
    g_total_out = 0;
    g_underflow_bytes = 0;

    g_seen_first_push = 0;

    g_backend_calls = 0;
    g_backend_bytes = 0;
    g_backend_peak = 0;

    memset(g_ring, 0, sizeof(g_ring));
    ring_unlock(state);
}

static u32 ring_write(const u8 *src, u32 len)
{
    u32 free_bytes;
    u32 to_write;
    u32 i;
    int state;

    ring_lock(&state);

    free_bytes = ring_free_nolock();
    to_write = len;
    if (to_write > free_bytes)
        to_write = free_bytes;

    for (i = 0; i < to_write; i++) {
        g_ring[g_ring_wpos] = src[i];
        g_ring_wpos++;
        if (g_ring_wpos >= LIBSDPCM_RING_SIZE)
            g_ring_wpos = 0;
    }

    g_ring_used += to_write;
    g_total_in += to_write;

    if (len > to_write)
        g_drop_bytes += (len - to_write);

    ring_unlock(state);
    return to_write;
}

static u32 ring_read(u8 *dst, u32 len)
{
    u32 to_read;
    u32 i;
    int state;

    ring_lock(&state);

    to_read = len;
    if (to_read > g_ring_used)
        to_read = g_ring_used;

    for (i = 0; i < to_read; i++) {
        dst[i] = g_ring[g_ring_rpos];
        g_ring_rpos++;
        if (g_ring_rpos >= LIBSDPCM_RING_SIZE)
            g_ring_rpos = 0;
    }

    g_ring_used -= to_read;
    g_total_out += to_read;

    ring_unlock(state);
    return to_read;
}

static void backend_measure_peak(const u8 *buf, u32 bytes)
{
    const s16 *pcm = (const s16 *)buf;
    u32 count = bytes >> 1;
    u32 i;
    s32 peak = 0;

    for (i = 0; i < count; i++) {
        s32 v = pcm[i];
        if (v < 0)
            v = -v;
        if (v > peak)
            peak = v;
    }

    g_backend_calls++;
    g_backend_bytes += bytes;
    g_backend_peak = peak;
}

static void backend_hw_init(void)
{
    int ret;

    if (g_backend_hw_inited)
        return;

    memset(g_hwbuf, 0, sizeof(g_hwbuf));

    ret = sceSdInit(SD_INIT_COLD);
    printf("[LPCM-IOP] HW init sceSdInit -> %d\n", ret);

#ifdef SD_PARAM_MVOLL
    sceSdSetParam(SD_CORE_1 | SD_PARAM_MVOLL, 0x3fff);
#endif
#ifdef SD_PARAM_MVOLR
    sceSdSetParam(SD_CORE_1 | SD_PARAM_MVOLR, 0x3fff);
#endif
#ifdef SD_PARAM_BVOLL
    sceSdSetParam(SD_CORE_1 | SD_PARAM_BVOLL, 0x3fff);
#endif
#ifdef SD_PARAM_BVOLR
    sceSdSetParam(SD_CORE_1 | SD_PARAM_BVOLR, 0x3fff);
#endif

#ifdef SD_C_ATTR_MUTE
    sceSdSetCoreAttr(SD_CORE_1 | SD_C_ATTR_MUTE, 0);
#endif

#ifdef SD_SWITCH_MMIX
    sceSdSetSwitch(SD_CORE_1 | SD_SWITCH_MMIX, 0x00f0);
#endif
#ifdef SD_SWITCH_VMIXEL
    sceSdSetSwitch(SD_CORE_1 | SD_SWITCH_VMIXEL, 0xffff);
#endif
#ifdef SD_SWITCH_VMIXER
    sceSdSetSwitch(SD_CORE_1 | SD_SWITCH_VMIXER, 0xffff);
#endif

    ret = sceSdBlockTrans(LIBSDPCM_DMA_CH, SD_TRANS_LOOP, (u8 *)g_hwbuf, sizeof(g_hwbuf), 0);
    printf("[LPCM-IOP] HW init sceSdBlockTrans LOOP -> %d size=%u ch=%d\n",
           ret, (unsigned)sizeof(g_hwbuf), LIBSDPCM_DMA_CH);

    g_backend_dma_started = 1;
    g_backend_hw_inited = 1;
}

static void backend_hw_shutdown(void)
{
    int ret;

    if (!g_backend_dma_started)
        return;

    ret = sceSdBlockTrans(LIBSDPCM_DMA_CH, SD_TRANS_STOP, NULL, 0, 0);
    printf("[LPCM-IOP] HW shutdown sceSdBlockTrans STOP -> %d\n", ret);

    g_backend_dma_started = 0;
}

static void backend_consume_pcm(const u8 *buf, u32 bytes)
{
    u32 status;
    int block;
    u32 copy_bytes = bytes;

    backend_measure_peak(buf, bytes);

    if (!g_backend_hw_inited)
        backend_hw_init();

    if (!g_backend_dma_started)
        return;

    status = (u32)sceSdBlockTransStatus(LIBSDPCM_DMA_CH, 0);
    block = 1 - (int)((status >> 24) & 1);

    if (block < 0 || block > 1)
        block = 0;

    if (copy_bytes > LIBSDPCM_PLAY_CHUNK)
        copy_bytes = LIBSDPCM_PLAY_CHUNK;

    memcpy(g_hwbuf[block], buf, copy_bytes);

    if (copy_bytes < LIBSDPCM_PLAY_CHUNK) {
        memset(&g_hwbuf[block][copy_bytes], 0, LIBSDPCM_PLAY_CHUNK - copy_bytes);
    }

    g_backend_last_block = block;

    if (g_backend_calls == 1 || (g_backend_calls % 32) == 0) {
        printf("[LPCM-IOP] BACKEND calls=%lu bytes=%lu peak=%ld block=%d status=0x%08lx first=%02x %02x %02x %02x\n",
               (unsigned long)g_backend_calls,
               (unsigned long)g_backend_bytes,
               (long)g_backend_peak,
               block,
               (unsigned long)status,
               buf[0], buf[1], buf[2], buf[3]);
    }
}

static void player_thread(void *arg)
{
    u32 got;
    int state;
    u32 used_now;
    u32 free_now;
    u32 delay_now;
    int started = 0;
    u32 idle_loops = 0;

    (void)arg;

    printf("[LPCM-IOP] player thread enter\n");

    while (1) {
        if (!g_audio_initialized) {
            started = 0;
            idle_loops = 0;
            DelayThread(10000);
            continue;
        }

        ring_lock(&state);
        used_now = g_ring_used;
        free_now = ring_free_nolock();
        ring_unlock(state);

        if (!started) {
            if (!g_seen_first_push) {
                DelayThread(10000);
                continue;
            }

            if (used_now < LIBSDPCM_PREFILL_START) {
                idle_loops++;
                if (idle_loops == 1 || (idle_loops % 64) == 0) {
                    printf("[LPCM-IOP] PREFILL wait used=%lu target=%u\n",
                           (unsigned long)used_now, LIBSDPCM_PREFILL_START);
                }
                DelayThread(6000);
                continue;
            }

            started = 1;
            idle_loops = 0;
            printf("[LPCM-IOP] PREFILL reached used=%lu\n", (unsigned long)used_now);
        }

        got = ring_read(g_play_buf, LIBSDPCM_PLAY_CHUNK);
        g_pop_calls++;

        if (got < LIBSDPCM_PLAY_CHUNK)
            g_underflow_bytes += (LIBSDPCM_PLAY_CHUNK - got);

        if (got > 0)
            backend_consume_pcm(g_play_buf, got);

        ring_lock(&state);
        used_now = g_ring_used;
        free_now = ring_free_nolock();
        ring_unlock(state);

        delay_now = (used_now > (48 * 1024)) ? LIBSDPCM_PLAY_DELAY_FAST : LIBSDPCM_PLAY_DELAY_NORM;

        if (g_pop_calls == 1 || (g_pop_calls % 32) == 0) {
            printf("[LPCM-IOP] POP calls=%lu got=%lu used=%lu free=%lu under=%lu drops=%lu delay=%lu peak=%ld block=%d first=%02x %02x %02x %02x\n",
                   (unsigned long)g_pop_calls,
                   (unsigned long)got,
                   (unsigned long)used_now,
                   (unsigned long)free_now,
                   (unsigned long)g_underflow_bytes,
                   (unsigned long)g_drop_bytes,
                   (unsigned long)delay_now,
                   (long)g_backend_peak,
                   g_backend_last_block,
                   g_play_buf[0], g_play_buf[1], g_play_buf[2], g_play_buf[3]);
        }

        DelayThread(delay_now);
    }
}

static void *libsdpcm_rpc_handler(int fno, void *data, int size)
{
    libsdpcm_rpc_pkt_t *pkt = (libsdpcm_rpc_pkt_t *)data;
    u32 wrote;
    int state;
    u32 used_now;
    u32 free_now;

    (void)fno;
    (void)size;

    if (!pkt)
        return data;

    pkt->magic = LIBSDPCM_RPC_ID;
    pkt->counter = ++g_rpc_counter;
    pkt->result = -1;

    switch (pkt->cmd) {
        case LIBSDPCM_CMD_PING:
            ring_lock(&state);
            used_now = g_ring_used;
            free_now = ring_free_nolock();
            ring_unlock(state);

            pkt->result = 1;
            printf("[LPCM-IOP] PING ok used=%lu free=%lu drops=%lu under=%lu\n",
                   (unsigned long)used_now,
                   (unsigned long)free_now,
                   (unsigned long)g_drop_bytes,
                   (unsigned long)g_underflow_bytes);
            break;

        case LIBSDPCM_CMD_INIT:
            ring_reset();
            backend_hw_shutdown();
            g_backend_hw_inited = 0;
            g_backend_dma_started = 0;
            g_backend_last_block = -1;
            g_audio_initialized = 1;
            printf("[LPCM-IOP] INIT ok buffer=%u bytes chunk=%u prefill=%u fast=%u norm=%u\n",
                   LIBSDPCM_RING_SIZE, LIBSDPCM_PLAY_CHUNK,
                   LIBSDPCM_PREFILL_START,
                   LIBSDPCM_PLAY_DELAY_FAST,
                   LIBSDPCM_PLAY_DELAY_NORM);
            pkt->result = 1;
            break;

        case LIBSDPCM_CMD_QUIT:
            g_audio_initialized = 0;
            backend_hw_shutdown();
            printf("[LPCM-IOP] QUIT ok in=%lu out=%lu drops=%lu under=%lu used=%lu\n",
                   (unsigned long)g_total_in,
                   (unsigned long)g_total_out,
                   (unsigned long)g_drop_bytes,
                   (unsigned long)g_underflow_bytes,
                   (unsigned long)g_ring_used);
            pkt->result = 1;
            break;

        case LIBSDPCM_CMD_PUSH:
            g_push_calls++;
            if (!g_audio_initialized) {
                pkt->result = -2;
                break;
            }

            wrote = ring_write(pkt->payload, pkt->arg0);
            pkt->result = (s32)wrote;

            if (wrote > 0 && !g_seen_first_push) {
                g_seen_first_push = 1;
                printf("[LPCM-IOP] FIRST PUSH wrote=%lu used=%lu\n",
                       (unsigned long)wrote,
                       (unsigned long)g_ring_used);
            }

            if (g_push_calls == 1 || (g_push_calls % 32) == 0) {
                ring_lock(&state);
                used_now = g_ring_used;
                free_now = ring_free_nolock();
                ring_unlock(state);

                printf("[LPCM-IOP] PUSH calls=%lu in=%lu wrote=%lu used=%lu free=%lu drops=%lu first=%02x %02x %02x %02x\n",
                       (unsigned long)g_push_calls,
                       (unsigned long)pkt->arg0,
                       (unsigned long)wrote,
                       (unsigned long)used_now,
                       (unsigned long)free_now,
                       (unsigned long)g_drop_bytes,
                       pkt->payload[0], pkt->payload[1], pkt->payload[2], pkt->payload[3]);
            }
            break;

        default:
            pkt->result = -99;
            printf("[LPCM-IOP] unknown cmd=%lu\n", (unsigned long)pkt->cmd);
            break;
    }

    return data;
}

static void libsdpcm_rpc_thread(void *arg)
{
    int tid;
    (void)arg;

    SifSetSreg(16, 0xA200);

    SifInitRpc(0);
    SifSetSreg(16, 0xA210);

    tid = GetThreadId();
    SifSetRpcQueue(&g_qd, tid);
    SifSetSreg(16, 0xA220);

    SifRegisterRpc(&g_sd0, LIBSDPCM_RPC_ID, libsdpcm_rpc_handler, &g_rpc_buf, NULL, NULL, &g_qd);
    SifSetSreg(16, 0xA230);

    SifRpcLoop(&g_qd);
}

int _start(int argc, char *argv[])
{
    iop_thread_t t;
    int tid;
    int ret;

    (void)argc;
    (void)argv;

    FlushDcache();
    CpuEnableIntr();
    SifSetSreg(16, 0xA100);

    memset(&t, 0, sizeof(t));
    t.attr      = TH_C;
    t.thread    = libsdpcm_rpc_thread;
    t.priority  = 40;
    t.stacksize = 0x2000;
    t.option    = 0;

    tid = CreateThread(&t);
    if (tid < 0) {
        SifSetSreg(16, 0xA101);
        return MODULE_NO_RESIDENT_END;
    }

    ret = StartThread(tid, NULL);
    if (ret < 0) {
        SifSetSreg(16, 0xA102);
        return MODULE_NO_RESIDENT_END;
    }

    SifSetSreg(16, 0xA110);

    memset(&t, 0, sizeof(t));
    t.attr      = TH_C;
    t.thread    = player_thread;
    t.priority  = 41;
    t.stacksize = 0x2000;
    t.option    = 0;

    g_player_tid = CreateThread(&t);
    if (g_player_tid >= 0)
        StartThread(g_player_tid, NULL);

    return MODULE_RESIDENT_END;
}
